# AbuseIPDB API key. Create one in the AbuseIPDB account panel.
# Without this key, abeiplinux still builds the Europe allowlist, but AbuseIPDB sets stay empty.
ABUSEIPDB_API_KEY=""

# AbuseIPDB blacklist filters.
ABUSEIPDB_CONFIDENCE_MINIMUM="90"
ABUSEIPDB_LIMIT="10000"
ABUSEIPDB_DAYS="30"

# SSH filtering.
SSH_PORT="22"
ENABLE_EUROPE_ALLOWLIST="yes"

# Always-allow list. These addresses can reach SSH even when they are outside
# the Europe allowlist or appear on the AbuseIPDB blacklist. Space-separated,
# IPv4 and IPv6, single addresses or CIDR ranges. Example:
# WHITELIST="203.0.113.10 198.51.100.0/24 2001:db8::/48"
WHITELIST=""

# Countries used for the Europe allowlist. Values are ISO 3166-1 alpha-2 lowercase codes.
COUNTRIES="ad al am at ax az ba be bg by ch cy cz de dk ee es fi fo fr gb ge gg gi gr hr hu ie im is it je li lt lu lv mc md me mk mt nl no pl pt ro rs ru se si sk sm tr ua va xk"
