# AbuseIPDB API key. Create one in the AbuseIPDB account panel.
# Without this key, abeiplinux still builds the geo rules, but the AbuseIPDB
# sets stay empty.
ABUSEIPDB_API_KEY=""

# AbuseIPDB blacklist filters.
ABUSEIPDB_CONFIDENCE_MINIMUM="90"
ABUSEIPDB_LIMIT="10000"
ABUSEIPDB_DAYS="30"

# Always-allow list. These addresses can reach any port even when they are
# outside an allowed geo or appear on the AbuseIPDB blacklist. Space-separated,
# IPv4 and IPv6, single addresses or CIDR ranges. Example:
# WHITELIST="203.0.113.10 198.51.100.0/24 2001:db8::/48"
WHITELIST=""

# How long a downloaded country zone is reused before being refreshed, in hours.
# The systemd timer runs twice a day; with 20h the early run downloads and the
# later run reuses the cache.
ZONE_CACHE_HOURS="20"

# Region macros referenced by name in rules.conf. Values are ISO 3166-1 alpha-2
# lowercase codes. Add your own REGION_<NAME> variables as needed; the name in
# rules.conf is the lowercased part after REGION_ (e.g. REGION_NORDICS -> nordics).
REGION_EUROPE="ad al am at ax az ba be bg by ch cy cz de dk ee es fi fo fr gb ge gg gi gr hr hu ie im is it je li lt lu lv mc md me mk mt nl no pl pt ro rs ru se si sk sm tr ua va xk"
REGION_NORTH_AMERICA="us ca mx"
REGION_SOUTH_AMERICA="ar bo br cl co ec gy pe py sr uy ve"
REGION_OCEANIA="au nz fj pg"
